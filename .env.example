# SafeHer AI - Environment Variables
# Copy this file to .env and fill in your values
# ⚠️ NEVER commit .env file to Git!

# ============================================
# OPTIONAL: SMS Alerts via Twilio
# ============================================
# Sign up at https://www.twilio.com
# Get credentials from https://console.twilio.com

TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1234567890
EMERGENCY_CONTACT=+0987654321

# ============================================
# OPTIONAL: Email Alerts via SMTP
# ============================================
# For Gmail: Enable 2FA and create App Password
# https://myaccount.google.com/apppasswords

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_ADDRESS=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-here
EMERGENCY_EMAIL=emergency-contact@email.com

# ============================================
# API Configuration
# ============================================
API_HOST=0.0.0.0
API_PORT=8000

# ============================================
# NOTE: App works without these variables!
# Alerts will be logged instead of sent.
# ============================================
